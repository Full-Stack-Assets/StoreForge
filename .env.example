# Content generation — template mode works with NO API key (default).
# Sites and hourly posts use rotating editorial templates automatically.

# Provider selection: auto | template | groq | openrouter | openai | gemini
# auto picks the first configured key below (recommended: groq — free tier at console.groq.com)
CONTENT_PROVIDER=auto

# Recommended alternative to Gemini (free tier): https://console.groq.com/
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — one key, many models including free options: https://openrouter.ai/
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-2-9b-it:free

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini (optional)
# GEMINI_API_KEY=

# Force template-only mode (no AI calls)
# DISABLE_AI_CONTENT=true
