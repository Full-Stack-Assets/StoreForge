PORT=3000
STORE_NAME=StoreForge

# Public URL of this StoreForge deployment (used in generated blog links)
# STOREFORGE_URL=https://your-project.vercel.app

# Protect POST /api/blog-sites/generate (Bearer token or x-cron-secret header)
# CRON_SECRET=your-random-secret

# Optional: Gemini-powered post generation (falls back to templates if unset)
# GEMINI_API_KEY=your-gemini-key

# Required for Stripe checkout
STRIPE_SECRET_KEY=sk_live_xxx

# Base URL of your frontend (used for success/cancel redirects)
FRONTEND_URL=https://your-frontend.example.com

# Optional CORS allowlist (comma-separated)
# CORS_ORIGIN=https://your-frontend.example.com,https://admin.your-frontend.example.com

# GitHub Actions: optional Vercel redeploy hook after each new blog site commit
# (keeps the main dashboard deployment in sync with the registry)
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Deploy each generated site as its own standalone Vercel project
# Create a token at https://vercel.com/account/tokens
# VERCEL_TOKEN=your-vercel-api-token
# Required only if the token belongs to a team scope
# VERCEL_TEAM_ID=team_xxx
# Prefix for per-site Vercel project names (default: storeforge)
# VERCEL_PROJECT_PREFIX=storeforge
